  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2"
  }

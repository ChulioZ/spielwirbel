{
  "name": "game-sessions",
  "version": "1.0.0",
  "description": "Familien-Spielesammlung: a small, local-only web app to manage games, run voting sessions and track ratings.",
  "type": "commonjs",
  "main": "server.js",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test",

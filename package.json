{
  "name": "game-sessions",
  "version": "1.0.0",
  "description": "Spieleabend: a small, local-only web app to manage games, run voting sessions and track ratings.",
  "type": "commonjs",
  "main": "server.js",
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "start:env": "node --env-file-if-exists=.env server.js",
    "build": "node scripts/build.js",
    "migrate:postgres": "node scripts/migrate-json-to-postgres.js",
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage",
    "coverage:ci": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=85 --test-coverage-branches=80",
    "lint": "eslint .",
    "check:syntax": "find . -path ./node_modules -prune -o -path ./data -prune -o -path ./dist -prune -o -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "multer": "^2.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2"
  }
}

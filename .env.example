# Environment variables for Spielwirbel. Copy this file to `.env` and fill in
# the values you need, then start the server with `npm run start:env` (Node
# loads `.env` via --env-file-if-exists; a missing `.env` is fine).
#
# `.env` is gitignored — never commit real secrets. Everything here is OPTIONAL:
# the app runs fully with none of these set.

# Enables the AI "buy-next" game suggestions on a round's Start tab. Create a
# key in the Anthropic Console (console.anthropic.com) — this is the pay-as-you-
# go Developer Platform, billed separately from any Claude.ai subscription.
# Without it, the button reports it isn't set up; the local suggestions still work.
ANTHROPIC_API_KEY=

# HTTP port (default 3000).
# PORT=3000

# Where all user data lives (default ./data).
# DATA_DIR=./data

# Persistence backend (issue #127). Unset (the default) uses the local JSON file
# store at DATA_DIR/data.json — zero-dependency, right for local/home use. Set
# DATABASE_URL to a PostgreSQL connection string to use Postgres instead (the
# stateless-app-tier path for a hosted deployment); the app ensures its schema on
# startup. DATABASE_SSL=true enables TLS to the DB (managed Postgres usually needs
# it; a local/CI container does not).
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL=true

# Cover-image storage (issue #128). Unset (the default) stores cover images as
# files under DATA_DIR/uploads. Set S3_BUCKET to use S3-compatible object storage
# instead — the stateless-app-tier path so uploads survive an ephemeral/scaled
# host. Only the /uploads/<key> path is stored in the DB either way; the app
# streams objects back through /uploads (kept behind the auth gate). Works with
# AWS S3, Cloudflare R2, Backblaze B2, MinIO, etc. Credentials are optional: if
# S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY are unset, the AWS default provider chain
# (AWS_* env, IAM role) is used. Set S3_ENDPOINT for non-AWS stores (and usually
# S3_FORCE_PATH_STYLE=true for MinIO). S3_PREFIX namespaces keys in a shared bucket.
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=

# Trust an upstream reverse proxy (for TLS termination). Set to the number of
# proxy hops (e.g. 1) or `true` so the real client IP is read from
# X-Forwarded-For and rate limiting keys on it. Leave unset for a direct
# deployment. (default: off)
# TRUST_PROXY=1

# Rate-limit ceilings, per IP. Global: requests per 15 min (default 1000).
# Recommendations POST (the billable Claude call): requests per hour (default 15).
# RATE_LIMIT_MAX=1000
# RECS_RATE_LIMIT_MAX=15

# Per-tenant quotas & abuse controls (issue #139). These bound cost/abuse in the
# public multi-tenant mode and are ENFORCED ONLY when ACCOUNTS_ENABLED=true — with
# accounts off (today's single-tenant deploy) they're inert. MAX_ROUNDS_PER_TENANT:
# rounds one account may own (default 10). MAX_GAMES_PER_ROUND: games (active +
# retired) one round may hold (default 1000). RECS_TENANT_MONTHLY_MAX: successful
# buy-next generations per tenant per calendar month (default 1) — this caps the
# billed Claude spend PER TENANT, on top of the per-IP RECS_RATE_LIMIT_MAX above.
# MAX_ROUNDS_PER_TENANT=10
# MAX_GAMES_PER_ROUND=1000
# RECS_TENANT_MONTHLY_MAX=1

# Authentication gate (issue #129). Set AUTH_PASSWORD to require a single shared
# login for the whole app; unset (the default) leaves a bare local checkout
# fully open — the production deployment sets this. SESSION_SECRET signs the
# session cookie — set it to a long random string in a real deployment; if
# unset it falls back to AUTH_PASSWORD. AUTH_RATE_LIMIT_MAX caps login attempts
# per 15 min (default 20).
# AUTH_PASSWORD=
# SESSION_SECRET=
# AUTH_RATE_LIMIT_MAX=20

# User accounts (issue #135): the token-first account model (register, e-mail
# verification, login with access/refresh tokens, password reset), meant to
# eventually replace the shared-password gate. Tenancy (#136) and the
# onboarding UI (#138) have both shipped, so the feature is complete — OFF by
# default is now a deliberate ops choice (opening public sign-up needs the
# legal pack first, see docs/production-readiness.md §9/§12), not a
# dependency wait. Set ACCOUNTS_ENABLED=true AND a strong SESSION_SECRET (it
# signs the access tokens) to expose /api/account.
# ACCOUNTS_ENABLED=true

# Outbound transactional e-mail for the account flows (Brevo, EU provider).
# Unset (the default): nothing is sent — messages are logged and kept in an
# in-memory outbox, which is what dev and the test suite use. MAIL_FROM must be
# a sender address verified in your Brevo account. APP_BASE_URL builds the links
# inside the mails (default http://localhost:PORT).
# BREVO_API_KEY=
# MAIL_FROM=no-reply@example.com
# MAIL_FROM_NAME=Spielwirbel
# APP_BASE_URL=https://example.com

# Observability (issue #132). Structured request/error logs go to stdout as JSON.
# LOG_LEVEL controls verbosity: silent | error | warn | info (default info).
# LOG_LEVEL=info
# Optional error alerting: if set, the central error handler POSTs a compact,
# personal-data-free notification (method, path, message) to this webhook on any
# unexpected 500 — e.g. a Slack/Discord incoming webhook. Leave unset to disable.
# ERROR_WEBHOOK_URL=

# Add-game lookup provider locales/regions (defaults shown).
# PSSTORE_LOCALE=de-de
# STEAM_CC=de
# STEAM_LOCALE=german
# NINTENDO_LOCALE=de
# XBOX_LOCALE=de-de

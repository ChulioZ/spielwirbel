# Environment variables for Spieleabend. Copy this file to `.env` and fill in
# the values you need, then start the server with `npm run start:env` (Node
# loads `.env` via --env-file-if-exists; a missing `.env` is fine).
#
# `.env` is gitignored — never commit real secrets. Everything here is OPTIONAL:
# the app runs fully with none of these set.

# Enables the AI "buy-next" game suggestions on a round's Start tab. Create a
# key in the Anthropic Console (console.anthropic.com) — this is the pay-as-you-
# go Developer Platform, billed separately from any Claude.ai subscription.
# Without it, the button reports it isn't set up; the local suggestions still work.
ANTHROPIC_API_KEY=

# HTTP port (default 3000).
# PORT=3000

# Where all user data lives (default ./data).
# DATA_DIR=./data

# Add-game lookup provider locales/regions (defaults shown).
# PSSTORE_LOCALE=de-de
# STEAM_CC=de
# STEAM_LOCALE=german
# NINTENDO_LOCALE=de
# XBOX_LOCALE=de-de

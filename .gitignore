node_modules/

# Output of the optional cache-busting build (`npm run build`, issue #141).
# Regenerated from public/; never committed. Delete it to go back to serving
# the live-editable public/ tree.
dist/

# All user-specific data (rounds, sessions, uploaded cover images) lives here.
# Never publish it.
data/

*.bak
*.log
.DS_Store

# Local environment files may hold secrets (e.g. SESSION_SECRET) — never
# commit them. The committed template is .env.example (no secrets).
.env
.env.local
.env.*.local

# Claude Code local settings
.claude/settings.local.json
